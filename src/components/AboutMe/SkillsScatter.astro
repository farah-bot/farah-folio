---
interface Skill {
  id: string;
  name: string;
  color: string;
  order_index: number;
}

interface Props {
  skills: Skill[];
}

const { skills } = Astro.props;

const positions = [
  { x: 3,  y: 6  },
  { x: 50, y: 2  },
  { x: 40, y: 80 },
  { x: 2,  y: 56 },
  { x: 58, y: 44 },
  { x: 22, y: 12 },
  { x: 66, y: 16 },
  { x: 40, y: 60 },
];

const floatAnims = [
  { cls: 'animate-float-a', del: '0s'   },
  { cls: 'animate-float-b', del: '0.7s' },
  { cls: 'animate-float-c', del: '1.4s' },
  { cls: 'animate-float-d', del: '0.3s' },
  { cls: 'animate-float-e', del: '1.1s' },
  { cls: 'animate-float-f', del: '1.8s' },
  { cls: 'animate-float-g', del: '0.5s' },
  { cls: 'animate-float-h', del: '2.1s' },
];
---

<div class="relative" style="height:165px;" role="list" aria-label="Skills">
  {skills.map((skill, i) => {
    const pos  = positions[i % positions.length];
    const anim = floatAnims[i % floatAnims.length];
    return (
      <div
        role="listitem"
        class={`absolute inline-flex flex-col items-start cursor-default ${anim.cls} hover:z-10 hover:[animation-play-state:paused]`}
        style={`left:${pos.x}%; top:${pos.y}%; animation-delay:${anim.del};`}
        aria-label={skill.name}
      >
        <span
          class="text-[15px] -ml-2 -mb-2.5 leading-none"
          style={`color:${skill.color}; transform:rotate(-28deg); filter:drop-shadow(0 1px 2px rgba(0,0,0,0.4));`}
          aria-hidden="true"
        >▶</span>
        <span
          class="inline-flex items-center px-3.5 py-1.5 rounded-full text-[11px] font-bold
                 font-display tracking-[0.07em] text-white whitespace-nowrap
                 border border-white/15 shadow-[0_4px_16px_rgba(0,0,0,0.35)]
                 hover:brightness-110 hover:shadow-[0_6px_24px_rgba(0,0,0,0.55)]
                 transition-all duration-150"
          style={`background:${skill.color};`}
        >
          {skill.name}
        </span>
      </div>
    );
  })}
</div>

---
interface Props {
  name: string;
  role: string;
  company: string;
  company_url: string;
}

const { name, role, company, company_url } = Astro.props;
const firstName = name.split(' ')[0];
---

<div id="hero-card" role="presentation">
  <div class="hero-text">
    <p>Hey, I'm&nbsp;<span class="pill pill-purple">{firstName}&nbsp;👩🏻‍💻</span></p>
    <p>I'm a&nbsp;<span class="pill pill-orange">{role.toLowerCase()},</span></p>
    <p>
      currently at&nbsp;
      <a
        href={company_url}
        target="_blank"
        rel="noopener noreferrer"
        class="pill pill-green burst-origin"
        aria-label={`${company} - external link`}
      >
        {company}&nbsp;↗
      </a>
    </p>
  </div>
</div>

<style>
@keyframes cardIn {
  from { opacity: 0; transform: scale(0.92) translateY(12px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}

#hero-card {
  position: relative;
  z-index: 10;
  background: rgba(18,18,18,0.9);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 28px;
  padding: 52px 64px;
  text-align: center;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow:
    0 0 0 1px rgba(255,255,255,0.04) inset,
    0 32px 80px rgba(0,0,0,0.6);
  opacity: 0;
  animation: cardIn 0.7s cubic-bezier(0.34,1.2,0.64,1) 0.2s forwards;
}

.hero-text {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.hero-text p {
  font-size: clamp(1.5rem, 3vw, 2.15rem);
  font-weight: 800;
  font-family: 'Syne', sans-serif;
  color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  line-height: 1.3;
}

@media (max-width: 768px) {
  #hero-card { padding: 36px 28px; }
  .hero-text p { font-size: 1.4rem; }
}
</style>
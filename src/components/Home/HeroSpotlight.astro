
<div id="spotlight" aria-hidden="true"></div>

<style>
#spotlight {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
  background: radial-gradient(
    400px circle at var(--sx, 50%) var(--sy, 50%),
    rgba(124,58,237,0.07) 0%,
    transparent 70%
  );
  opacity: 0;
  transition: opacity 0.3s ease;
}

.particle {
  position: fixed;
  width: 6px; height: 6px;
  border-radius: 50%;
  pointer-events: none;
  z-index: 9999;
  animation: particleFly 0.7s ease-out forwards;
}
@keyframes particleFly {
  0%   { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(var(--px), var(--py)) scale(0); opacity: 0; }
}
</style>

<script>
const hero      = document.getElementById('hero')      as HTMLElement;
const spotlight = document.getElementById('spotlight') as HTMLElement;
const heroCard  = document.getElementById('hero-card') as HTMLElement;

if (hero && spotlight) {
  hero.addEventListener('mouseenter', () => { spotlight.style.opacity = '1'; });
  hero.addEventListener('mouseleave', () => { spotlight.style.opacity = '0'; });
  hero.addEventListener('mousemove', (e: MouseEvent) => {
    const rect = hero.getBoundingClientRect();
    spotlight.style.setProperty('--sx', `${((e.clientX - rect.left) / rect.width)  * 100}%`);
    spotlight.style.setProperty('--sy', `${((e.clientY - rect.top)  / rect.height) * 100}%`);
  });
}

if (heroCard) {
  heroCard.addEventListener('mouseenter', () => {
    heroCard.style.transition = 'transform 0.1s ease';
  });

  heroCard.addEventListener('mousemove', (e: MouseEvent) => {
    const { left, top, width, height } = heroCard.getBoundingClientRect();
    const rx = ((e.clientY - top  - height / 2) / height) * -12;
    const ry = ((e.clientX - left - width  / 2) / width)  *  12;
    heroCard.style.transform = `perspective(800px) rotateX(${rx}deg) rotateY(${ry}deg) scale(1.02)`;
  });

  heroCard.addEventListener('mouseleave', () => {
    heroCard.style.transition = 'transform 0.5s cubic-bezier(0.34,1.2,0.64,1)';
    heroCard.style.transform  = 'perspective(800px) rotateX(0) rotateY(0) scale(1)';
    setTimeout(() => { heroCard.style.transition = ''; }, 500);
  });
}

const COLORS = ['#7c3aed', '#f97316', '#22c55e', '#fb923c', '#9b6ef7', '#fbbf24'];

document.querySelectorAll<HTMLElement>('.pill, .burst-origin').forEach(el => {
  el.addEventListener('click', (e: MouseEvent) => {
    const COUNT = 14;
    for (let i = 0; i < COUNT; i++) {
      const angle = (360 / COUNT) * i + Math.random() * 20;
      const dist  = 60 + Math.random() * 60;
      const rad   = (angle * Math.PI) / 180;

      const p = Object.assign(document.createElement('span'), { className: 'particle' });
      Object.assign(p.style, {
        left:       `${e.clientX}px`,
        top:        `${e.clientY}px`,
        background: COLORS[Math.floor(Math.random() * COLORS.length)],
        animationDelay: `${Math.random() * 80}ms`,
      });
      p.style.setProperty('--px', `${Math.cos(rad) * dist}px`);
      p.style.setProperty('--py', `${Math.sin(rad) * dist}px`);

      document.body.appendChild(p);
      setTimeout(() => p.remove(), 800);
    }
  });
});
</script>